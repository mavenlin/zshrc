#!/usr/bin/env bash
set -euo pipefail

NVM_DIR="${NVM_DIR:-$HOME/.nvm}"

if [[ ! -s "$NVM_DIR/nvm.sh" ]]; then
  echo "codex: nvm.sh not found under $NVM_DIR" >&2
  exit 127
fi

# shellcheck disable=SC1090
source "$NVM_DIR/nvm.sh" --no-use

node_path="$(nvm which default 2>/dev/null)" || {
  echo "codex: no default NVM node version is available" >&2
  exit 127
}

node_bin="${node_path%/node}"
codex_bin="$node_bin/codex"

if [[ ! -x "$codex_bin" ]]; then
  echo "codex: executable not found at $codex_bin" >&2
  exit 127
fi

export PATH="$node_bin:$PATH"
exec "$codex_bin" "$@"
